<!-- Simple mocap-controlled pusher arm (easy difficulty).
     ee_frame matches the SO-101 end-effector body name. -->
<mujoco model="simple_arm">
  <worldbody>
    <body name="mocap_target" mocap="true" pos="0.0 0 0.075">
      <geom type="sphere" size="0.008" rgba="1 0 0 0.6"
            contype="0" conaffinity="0"/>
    </body>
    <!-- Heavy dynamic body welded to mocap_target; does the actual pushing.
         Mass=2kg ensures contact forces push objects rather than deflecting. -->
    <body name="ee_frame" pos="0.0 0 0.075">
      <joint name="joint1" type="free"/>
      <geom type="cylinder" size="0.025 0.015" rgba="0.2 0.2 0.9 0.8"
            contype="1" conaffinity="1" mass="2.0"/>
    </body>
  </worldbody>
  <equality>
    <weld body1="ee_frame" body2="mocap_target"
          solref="0.002 1" solimp="0.99 0.999 0.0001"/>
  </equality>
</mujoco>
